{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"attributePosition": "auto",
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 90,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "always",
			"bracketSameLine": false,
			"bracketSpacing": true,
			"jsxQuoteStyle": "double",
			"quoteStyle": "single",
			"quoteProperties": "asNeeded",
			"semicolons": "asNeeded",
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
        "useImportType": "off"
			},
			"suspicious": {
				"noEmptyBlock": "off",
				"noUnknownAtRules": "off"
			},
			"correctness": {
				"noUnusedVariables": "off",
				"useExhaustiveDependencies": "off",
				"useHookAtTopLevel": "off"
			},
			"a11y": {
				"noLabelWithoutControl": "off",
				"useButtonType": "off",
				"useValidAnchor": "off"
			}
		}
	},
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
